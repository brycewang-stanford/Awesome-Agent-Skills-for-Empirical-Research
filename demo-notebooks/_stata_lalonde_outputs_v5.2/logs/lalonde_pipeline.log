> .json", write replace

. file write _f "[" _n

. file write _f `"  ["0. raw rdatasets csv", 614], "' _n

. file write _f `"  ["1. drop rownames + dropna", 614], "' _n

. file write _f `"  ["2. recode race -> black/hispan", 614], "' _n

. file write _f `"  ["3. enforce treat in {0,1}", `_n_final'] "' _n

. file write _f "]" _n

. file close _f

