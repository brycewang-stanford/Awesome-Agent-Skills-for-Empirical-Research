. qui reg re78 treat age educ black hispan married nodegree re74 re75, vce(robu
> st)

. local _b  = _b[treat]

. local _se = _se[treat]

. local _lo = `_b' - 1.96 * `_se'

. local _hi = `_b' + 1.96 * `_se'

. local _n  = e(N)

. 
. file open _f using "_stata_lalonde_outputs_v5.2/artifacts/result.json", write
>  replace
