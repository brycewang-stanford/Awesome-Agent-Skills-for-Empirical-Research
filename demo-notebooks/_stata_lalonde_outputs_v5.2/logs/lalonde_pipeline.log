. file write _f `"  "frozen_at": "2026-05-02", "' _n

. file write _f `"  "stata_command": "power twomeans 0, n1(185) n2(429) sd1(1) 
> sd2(1) alpha(0.05) power(0.80)""' _n

. file write _f "}" _n

. file close _f

