> w1 re75_w1, ///
>     vce(robust)

. 
. * (4) Common support (PS in [0.05, 0.95])
. preserve

.     capture drop _ps_h

.     qui logit treat age educ black hispan married nodegree re74 re75

.     predict _ps_h, pr

.     keep if inrange(_ps_h, 0.05, 0.95)
(158 observations deleted)

.     qui reg re78 treat age educ black hispan married nodegree re74 re75, vce(
> robust)

.     eststo h4

. restore

