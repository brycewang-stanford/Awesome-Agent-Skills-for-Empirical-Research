. *============================================================================
> =*
. local _cmds  esttab    coefplot  winsor2  balancetable  psmatch2  ebalance  p
> sacalc

. local _pkgs  estout    coefplot  winsor2  balancetable  psmatch2  ebalance  p
> sacalc

. local _N : word count `_cmds'

. forvalues i = 1/`_N' {
  2.     local _c : word `i' of `_cmds'
  3.     local _p : word `i' of `_pkgs'
  4.     capture which `_c'
  5.     if _rc {
  6.         di as text "[setup] installing `_p' from SSC ..."
  7.         capture noisily ssc install `_p', replace
  8.         if _rc di as error "[setup] 安装 `_p' 失败"
  9.     }
 10. }

. 
. * 全局画图主题
. set scheme s2color

. 
. * Journal style macros (skill §export cookbook — AER convention)
. local AER_STAR  "* 0.10 ** 0.05 *** 0.01"

. local AER_NOTES "Robust standard errors in parentheses. * p<0.10, ** p<0.05, 
> *** p<0.01."

. local AER_STATS stats(N r2_a, labels("N" "Adj. R²"))

