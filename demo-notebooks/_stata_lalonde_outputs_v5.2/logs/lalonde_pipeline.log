. *---------------------------------------------------------------------*
. * F4: 规范曲线 (skill §6.l — Figure 5/spec curve)                      *
. *---------------------------------------------------------------------*
. capture frame drop spec

. frame create spec

. frame spec: g double spec_id = .

. frame spec: g double b = .

. frame spec: g double se = .

. frame spec: g double lo = .

. frame spec: g double hi = .

. frame spec: g str30 label = ""

. local id 0

. local controls_list "treat treat age educ treat age educ black hispan treat a
> ge educ black hispan married nodegree"

. local n_controls : word count `controls_list'

. local n_models = `n_controls' / 4

. 
. forvalues m = 1/`n_models' {
  2.     local offset = (`m' - 1) * 4 + 1
  3.     local spec : word `offset' of `controls_list'
  4.     if `m' == 1 local spec_vars "treat"
  5.     else if `m' == 2 local spec_vars "treat age educ"
  6.     else if `m' == 3 local spec_vars "treat age educ black hispan"
  7.     else if `m' == 4 local spec_vars "treat age educ black hispan married 
> nodegree"
  8.     else if `m' == 5 local spec_vars "treat age educ black hispan married 
> nodegree re74 re75"
  9. 
.     foreach se_type in "robust" "" "hc3" {
 10.         if "`se_type'" == "" {
 11.             capture qui reg re78 `spec_vars'
 12.         }
 13.         else {
 14.             capture qui reg re78 `spec_vars', vce(`se_type')
 15.         }
 16.         if _rc == 0 {
 17.             local ++id
 18.             local b = _b[treat]
 19.             local se = _se[treat]
 20.             local lo = `b' - 1.96*`se'
 21.             local hi = `b' + 1.96*`se'
 22.             frame post spec (`id') (`b') (`se') (`lo') (`hi') ("M`m'/se=`s
> e_type'")
 23.         }
 24.     }
 25. }

. 
. frame change spec

. sort b

. gen rank = _n

. twoway (rcap lo hi rank, lcolor(gs8)) ///
>        (scatter b rank, mcolor(navy) msymbol(Oh)), ///
>     yline(0, lpattern(dash) lcolor(gs10)) ///
>     xtitle("Specification rank") ytitle("β̂(treat) — 95% CI") ///
>     title("Figure 4. Specification curve — treatment effect across 15 specs")
>  ///
>     legend(off) scheme(s2color)

. graph export "_stata_lalonde_outputs_v5.2/figures/fig4_spec_curve.pdf", repla
> ce
file _stata_lalonde_outputs_v5.2/figures/fig4_spec_curve.pdf saved as PDF
    format

