. local _pkgs  estout    coefplot  winsor2  balancetable  psmatch2  ebalance  p
> sacalc

. local _N : word count `_cmds'

. forvalues i = 1/`_N' {
  2.     local _c : word `i' of `_cmds'
  3.     local _p : word `i' of `_pkgs'
  4.     capture which `_c'
  5.     if _rc {
  6.         di as text "[setup] installing `_p' from SSC ..."
  7.         capture noisily ssc install `_p', replace
  8.         if _rc {
  9.             di as error "[setup] 安装 `_p' 失败：请检查网络或手动 ssc inst
> all `_p'"
 10.             exit _rc
 11.         }
 12.     }
 13. }

